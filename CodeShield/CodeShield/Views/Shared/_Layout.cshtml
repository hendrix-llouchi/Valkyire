<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Valkyrie</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CodeShield.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100 bg-light">
    <header class="container mt-4">
        <nav class="navbar navbar-expand-md navbar-light nb-navbar-container">
            <div class="container-fluid p-0">
                <a class="navbar-brand d-flex align-items-center gap-2 nb-brand-text" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.jpg" alt="Valkyrie Logo" class="brand-logo border border-2 border-dark rounded-0" /> Valkyrie
                </a>
                <button class="navbar-toggler border-2 border-dark rounded-0 p-1" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-md-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-md-4 align-items-md-center gap-2 gap-md-0">
                        <li class="nav-item">
                            <a class="nav-link nb-nav-link px-3" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="nb-nav-divider d-none d-md-inline">|</span>
                            <li class="nav-item">
                                <a class="nav-link nb-nav-link px-3" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>
                            <span class="nb-nav-divider d-none d-md-inline">|</span>
                            <li class="nav-item">
                                <a class="nav-link nb-nav-link px-3" asp-controller="Scan" asp-action="Index">New Scan</a>
                            </li>
                            <span class="nb-nav-divider d-none d-md-inline">|</span>
                            <li class="nav-item">
                                <a class="nav-link nb-nav-link px-3" asp-controller="Scan" asp-action="History">My Scans</a>
                            </li>
                        }
                        <span class="nb-nav-divider d-none d-md-inline">|</span>
                        <li class="nav-item">
                            <a class="nav-link nb-nav-link px-3" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container flex-grow-1 mt-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="nb-footer">
        <div class="container">
            <div class="row align-items-center g-3">
                <div class="col-md-6 text-center text-md-start">
                    <div class="nb-footer-brand">VALKYRIE</div>
                    <div class="nb-footer-subtext">2026. Built for builders.</div>
                </div>
                <div class="col-md-6 text-center text-md-end nb-footer-links">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                </div>
            </div>
        </div>
    </footer>
    <style>
        .nb-footer {
            position: relative !important;
            bottom: auto !important;
            left: auto !important;
            width: 100% !important;
            margin-top: auto !important;
            display: block !important;
        }
    </style>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
