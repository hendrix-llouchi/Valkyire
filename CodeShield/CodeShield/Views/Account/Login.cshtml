@model CodeShield.Models.LoginViewModel
@{
    ViewData["Title"] = "Log In";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="cs-card p-4 p-sm-5">
                <div class="text-center mb-4">
                    <span class="fs-1">🛡️</span>
                    <h2 class="fw-bold mt-2 text-dark">Welcome Back</h2>
                    <p class="text-muted small">Log in to monitor your codebase security</p>
                </div>
                
                <form asp-controller="Account" asp-action="Login" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post" novalidate>
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
                    {
                        <div class="alert cs-alert-danger p-3 mb-4 rounded-3" role="alert">
                            <div asp-validation-summary="ModelOnly" class="mb-0"></div>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold text-secondary small"></label>
                        <input asp-for="Email" class="form-control cs-input" placeholder="name@example.com" aria-required="true" />
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold text-secondary small"></label>
                        <input asp-for="Password" type="password" class="form-control cs-input" placeholder="••••••••" aria-required="true" />
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input class="form-check-input" asp-for="RememberMe" />
                        <label asp-for="RememberMe" class="form-check-label small text-muted">
                            Remember my login
                        </label>
                    </div>

                    <button class="w-100 cs-btn cs-btn-primary mb-3 text-white" type="submit">Log In</button>
                    
                    <div class="text-center mt-3">
                        <p class="text-muted small mb-0">
                            New to CodeShield? <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-semibold text-primary">Create an account</a>.
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
