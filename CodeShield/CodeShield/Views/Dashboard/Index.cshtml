@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-4">
    <!-- Welcome Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-5">
        <div>
            <h1 class="nb-heading mb-1" style="font-size: 2rem;">SECURITY CONTROL CENTER</h1>
            <p class="nb-mono text-muted small mb-0 text-uppercase">Welcome back, @(User.Identity?.Name). Overview of repository security.</p>
        </div>
        <div>
            <a asp-controller="Scan" asp-action="Index" class="nb-btn nb-btn-primary d-flex align-items-center gap-2">
                <span>🔍</span> SCAN REPOSITORY
            </a>
        </div>
    </div>

    <!-- Metrics Cards Grid -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="nb-card p-4 flex-row align-items-center justify-content-between">
                <div>
                    <p class="nb-mono text-muted small fw-bold text-uppercase mb-1">Total Scanned</p>
                    <h3 class="nb-heading mb-0" style="font-size: 1.5rem;">3 REPOSITORIES</h3>
                </div>
                <div class="nb-dashboard-icon-bg">📦</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="nb-card typical-theme p-4 flex-row align-items-center justify-content-between">
                <div>
                    <p class="nb-mono text-muted small fw-bold text-uppercase mb-1">Vulnerabilities</p>
                    <h3 class="nb-heading mb-0 text-danger" style="font-size: 1.5rem;">8 DETECTED</h3>
                </div>
                <div class="nb-dashboard-icon-bg text-danger">⚠️</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="nb-card rookie-theme p-4 flex-row align-items-center justify-content-between">
                <div>
                    <p class="nb-mono text-muted small fw-bold text-uppercase mb-1">Security Rating</p>
                    <h3 class="nb-heading mb-0 text-success" style="font-size: 1.5rem;">GRADE B</h3>
                </div>
                <div class="nb-grade-badge nb-grade-b">B</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Quick Scan Card -->
        <div class="col-lg-6">
            <div class="nb-card p-4 h-100 justify-content-between">
                <div>
                    <div class="fs-2 mb-3">🛡️</div>
                    <h5 class="nb-heading mb-2">RUN SECURITY CHECK</h5>
                    <p class="nb-mono text-secondary small mb-4">
                        Perform an on-demand scan of your public GitHub repositories. Valkyrie detects dependencies for npm and NuGet, and checks code patterns for security risks in C# and Python.
                    </p>
                </div>
                <div class="d-grid mt-auto">
                    <a asp-controller="Scan" asp-action="Index" class="nb-btn nb-btn-primary text-center">
                        LAUNCH SCANNER CONSOLE
                    </a>
                </div>
            </div>
        </div>

        <!-- Recent Scans List -->
        <div class="col-lg-6">
            <div class="nb-card p-4 h-100">
                <h5 class="nb-heading mb-4">RECENT SCAN ACTIVITY</h5>
                <div class="d-flex flex-column gap-3">
                    <div class="nb-dashboard-item">
                        <div class="d-flex align-items-center gap-3">
                            <span class="fs-4">🐍</span>
                            <div>
                                <h6 class="nb-heading mb-0" style="font-size: 0.95rem;">my-python-app</h6>
                                <span class="nb-mono text-muted" style="font-size: 0.75rem;">Scanned 2 hours ago</span>
                            </div>
                        </div>
                        <span class="nb-badge nb-badge-light adventurer-theme py-1 px-3" style="font-size: 0.7rem; box-shadow: 1px 1px 0px var(--color-black);">Python only</span>
                    </div>

                    <div class="nb-dashboard-item">
                        <div class="d-flex align-items-center gap-3">
                            <span class="fs-4">🟢</span>
                            <div>
                                <h6 class="nb-heading mb-0" style="font-size: 0.95rem;">express-web-server</h6>
                                <span class="nb-mono text-muted" style="font-size: 0.75rem;">Scanned yesterday</span>
                            </div>
                        </div>
                        <span class="nb-badge rookie-theme py-1 px-3" style="font-size: 0.7rem; box-shadow: 1px 1px 0px var(--color-black);">Grade A</span>
                    </div>

                    <div class="nb-dashboard-item">
                        <div class="d-flex align-items-center gap-3">
                            <span class="fs-4">🔵</span>
                            <div>
                                <h6 class="nb-heading mb-0" style="font-size: 0.95rem;">dotnet-monolith-api</h6>
                                <span class="nb-mono text-muted" style="font-size: 0.75rem;">Scanned 3 days ago</span>
                            </div>
                        </div>
                        <span class="nb-badge typical-theme py-1 px-3" style="font-size: 0.7rem; box-shadow: 1px 1px 0px var(--color-black);">Grade D</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
