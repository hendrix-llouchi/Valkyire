@{
    ViewData["Title"] = "Shield Your Code";
}

<div class="container py-5">
    <!-- Hero Section -->
    <div class="row align-items-center justify-content-center text-center py-5">
        <div class="col-lg-8">
            <span class="badge bg-light text-primary border px-3 py-2 rounded-pill fw-semibold mb-3">
                🛡️ Open Source Security Scanner
            </span>
            <h1 class="display-4 fw-bold text-dark tracking-tight mb-3">
                Shield Your Code from <span class="text-primary" style="background: linear-gradient(135deg, var(--primary-color), #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Security Risks</span>
            </h1>
            <p class="lead text-secondary mb-4 mx-auto style-width" style="max-width: 600px;">
                Scan GitHub repositories for vulnerable packages and insecure code patterns. Get instant AI-driven explanations and fix suggestions.
            </p>
            
            <div class="d-flex justify-content-center gap-3">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Scan" asp-action="Index" class="cs-btn cs-btn-primary text-white text-decoration-none">
                        Start New Scan
                    </a>
                    <a asp-controller="Dashboard" asp-action="Index" class="cs-btn btn btn-light border fw-semibold text-secondary text-decoration-none">
                        Go to Dashboard
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Register" class="cs-btn cs-btn-primary text-white text-decoration-none">
                        Get Started Free
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="cs-btn btn btn-light border fw-semibold text-secondary text-decoration-none">
                        Sign In
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div class="row g-4 mt-5 pt-4">
        <div class="col-md-4">
            <div class="cs-card cs-card-hover p-4 h-100">
                <div class="fs-2 mb-3 text-primary">📦</div>
                <h5 class="fw-bold text-dark">Dependency Scanning</h5>
                <p class="text-muted small mb-0">
                    Instantly analyze `package.json` and `.csproj` files against the OSV.dev database to detect outdated and vulnerable third-party packages.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="cs-card cs-card-hover p-4 h-100">
                <div class="fs-2 mb-3 text-primary">🔍</div>
                <h5 class="fw-bold text-dark">Code Pattern Analysis</h5>
                <p class="text-muted small mb-0">
                    Static check for C# and Python source files to catch hardcoded secrets, SQL injection risks, exposed configurations, and HTTP protocol issues.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="cs-card cs-card-hover p-4 h-100">
                <div class="fs-2 mb-3 text-primary">🤖</div>
                <h5 class="fw-bold text-dark">AI-Powered Fixes</h5>
                <p class="text-muted small mb-0">
                    Receive clear explanations of detected risks in plain English and obtain actionable code fix recommendations generated by AI.
                </p>
            </div>
        </div>
    </div>

    <!-- Trust Banner -->
    <div class="text-center mt-5 pt-5 subtle-divider">
        <p class="text-muted small text-uppercase fw-semibold tracking-wider">Supports Public Repositories for</p>
        <div class="d-flex justify-content-center gap-4 align-items-center opacity-75 mt-3">
            <span class="fw-bold text-secondary">🟢 npm (Node.js)</span>
            <span class="fw-bold text-secondary">🔵 NuGet (.NET)</span>
            <span class="fw-bold text-secondary">🐍 Python (Code Scanning)</span>
        </div>
    </div>
</div>
