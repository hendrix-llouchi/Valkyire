@model CodeShield.Models.ScanViewModel
@{
    ViewData["Title"] = "Scan Repository";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <!-- Scan Form Card -->
            <div class="nb-card p-4 p-md-5 mb-4" id="scan-form-card">
                <div class="text-center mb-4">
                    <span class="fs-1">🔍</span>
                    <h1 class="nb-heading mt-2 mb-2" style="font-size: 2rem;">SCAN GITHUB REPOSITORY</h1>
                    <p class="nb-mono text-muted small text-uppercase">Analyze a public GitHub repository for vulnerable dependencies and security issues.</p>
                </div>

                <form asp-controller="Scan" asp-action="Index" method="post" id="scan-form">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label for="RepositoryUrl" class="form-label nb-mono fw-bold text-dark small text-uppercase mb-2">GitHub Repository URL</label>
                        <input type="text" 
                               class="form-control nb-input w-100 @(Model.IsSubmitted && !string.IsNullOrEmpty(Model.ErrorMessage) ? "is-invalid" : "")" 
                               id="RepositoryUrl" 
                               name="RepositoryUrl" 
                               value="@Model.RepositoryUrl" 
                               placeholder="https://github.com/owner/repository" 
                               required />
                        
                        @if (Model.IsSubmitted && !string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <div class="invalid-feedback d-block mt-2 fw-bold text-danger nb-mono small">
                                ⚠️ @Model.ErrorMessage
                            </div>
                        }
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="nb-btn nb-btn-primary">Analyze Repository</button>
                    </div>
                </form>
            </div>

            <!-- Loading Spinner State -->
            <div class="nb-card p-5 mb-4 text-center d-none mx-auto" id="scan-loader" style="max-width: 650px;">
                <div class="d-flex flex-column align-items-center justify-content-center">
                    <!-- Centered Loading Button Badge -->
                    <div class="d-inline-flex align-items-center justify-content-center gap-2 nb-btn nb-btn-primary px-4 py-2 mb-4 disabled" style="cursor: not-allowed;">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="width: 1.2rem; height: 1.2rem; border-width: 3px;"></span>
                        <span class="nb-heading fs-6 mb-0 text-white">Analyzing Repository...</span>
                    </div>

                    <h4 class="nb-heading mb-3">SCAN IN PROGRESS</h4>
                    <p class="nb-mono text-muted small text-uppercase mb-0" style="line-height: 1.6; max-width: 520px;">Checking file structure, extracting package versions, scanning code patterns, and generating AI explanations. For repositories with many issues, this may take several minutes to respect API rate limits. Please do not close this window.</p>
                </div>
            </div>

            @if (Model.IsSubmitted && string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div id="scan-results-container">
                    <!-- Warning Banners -->
                    @if (Model.DetectedEcosystems != null && Model.DetectedEcosystems.Contains(CodeShield.Models.Ecosystem.Python) && !Model.DetectedEcosystems.Contains(CodeShield.Models.Ecosystem.Npm) && !Model.DetectedEcosystems.Contains(CodeShield.Models.Ecosystem.NuGet))
                    {
                        <div class="alert nb-alert-warning p-4 mb-4 d-flex align-items-start" id="python-warning-banner">
                            <span class="fs-3 me-3">⚠️</span>
                            <div>
                                <h5 class="alert-heading nb-heading mb-1" style="font-size: 1.1rem;">Python Package Scan Limitation</h5>
                                <p class="mb-0 small text-uppercase" style="font-size: 0.8rem; font-weight: 600;">Package vulnerability scanning is disabled for Python repositories. Code pattern scanning is active for Python source files, but no third-party dependency vulnerability checks are performed.</p>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.OsvWarningMessage))
                    {
                        <div class="alert nb-alert-warning p-4 mb-4 d-flex align-items-start" id="osv-warning-banner">
                            <span class="fs-3 me-3">⚠️</span>
                            <div>
                                <h5 class="alert-heading nb-heading mb-1" style="font-size: 1.1rem;">Partial Scan Results</h5>
                                <p class="mb-0 small text-uppercase" style="font-size: 0.8rem; font-weight: 600;">@Model.OsvWarningMessage</p>
                            </div>
                        </div>
                    }

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="nb-heading mb-0">SCAN RESULTS</h4>
                        <button onclick="window.print()" class="nb-btn nb-btn-secondary py-2 px-3 fs-6" style="box-shadow: 2.5px 2.5px 0px var(--color-black) !important;">
                            📄 EXPORT REPORT (PDF)
                        </button>
                    </div>

                    <!-- Tabs Control -->
                    <ul class="nav nb-nav-pills mb-4" id="scanTabs" role="tablist">
                        <li class="nav-item" role="presentation" style="flex: 1;">
                            <button class="nav-link w-100 active" id="packages-tab" data-bs-toggle="pill" data-bs-target="#packages-pane" type="button" role="tab" aria-controls="packages-pane" aria-selected="true">
                                📦 Package Dependencies
                            </button>
                        </li>
                        <li class="nav-item" role="presentation" style="flex: 1;">
                            <button class="nav-link w-100" id="issues-tab" data-bs-toggle="pill" data-bs-target="#issues-pane" type="button" role="tab" aria-controls="issues-pane" aria-selected="false">
                                🔍 Code Issues
                            </button>
                        </li>
                        <li class="nav-item" role="presentation" style="flex: 1;">
                            <button class="nav-link w-100" id="files-tab" data-bs-toggle="pill" data-bs-target="#files-pane" type="button" role="tab" aria-controls="files-pane" aria-selected="false">
                                📄 Repository File List
                            </button>
                        </li>
                    </ul>

                    <!-- Tabs Content -->
                    <div class="tab-content" id="scanTabsContent">
                        <!-- Packages Pane -->
                        <div class="tab-pane fade show active" id="packages-pane" role="tabpanel" aria-labelledby="packages-tab">
                            @if (Model.DetectedEcosystems != null && Model.DetectedEcosystems.Count > 0)
                            {
                                @foreach (var ecosystem in Model.DetectedEcosystems)
                                {
                                    var ecosystemName = ecosystem == CodeShield.Models.Ecosystem.Npm ? "npm" :
                                                         ecosystem == CodeShield.Models.Ecosystem.NuGet ? "NuGet" : "Python";
                                    var badgeColor = ecosystem == CodeShield.Models.Ecosystem.Npm ? "bg-warning text-dark" :
                                                     ecosystem == CodeShield.Models.Ecosystem.NuGet ? "bg-primary text-white" : "bg-info text-dark";
                                    var ecosystemPackages = Model.Packages?.Where(p => p.Ecosystem == ecosystem).ToList() ?? new List<CodeShield.Models.DependencyPackage>();

                                    <div class="nb-card p-4 mb-4">
                                        <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom border-dark">
                                            <h5 class="nb-heading mb-0 d-flex align-items-center gap-2">
                                                <span>@(ecosystem == CodeShield.Models.Ecosystem.Npm ? "🟢" : ecosystem == CodeShield.Models.Ecosystem.NuGet ? "🔵" : "🐍")</span> 
                                                @ecosystemName Packages
                                            </h5>
                                            <span class="nb-badge nb-badge-light py-1 px-3 fs-7">@ecosystemPackages.Count packages</span>
                                        </div>

                                        @if (ecosystem == CodeShield.Models.Ecosystem.Python)
                                        {
                                            <div class="alert nb-alert-warning p-3 mb-0">
                                                <p class="mb-0 small fw-bold">
                                                    ⚠️ Package dependency vulnerability scans are currently disabled for Python.
                                                </p>
                                            </div>
                                            @if (ecosystemPackages.Count == 0)
                                            {
                                                <div class="p-4 text-center text-muted nb-mono small">
                                                    No python dependency packages listed in requirements.txt
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="row g-2 mt-2">
                                                    @foreach (var pkg in ecosystemPackages)
                                                    {
                                                        <div class="col-md-6 col-lg-4">
                                                            <div class="p-2 border border-2 border-dark bg-white d-flex justify-content-between align-items-center nb-mono">
                                                                <span class="fw-bold text-dark small text-truncate" style="max-width: 120px;">@pkg.PackageName</span>
                                                                <span class="nb-badge nb-badge-light py-0 px-2 font-monospace small" style="box-shadow: none; border-width: 1px !important;">@pkg.Version</span>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            var vulnerablePackages = ecosystemPackages.Where(p => p.Vulnerabilities.Count > 0).ToList();
                                            var vulnPackageCount = vulnerablePackages.Count;
                                            var totalPackageCount = ecosystemPackages.Count;

                                            <div class="p-3 mb-3 @(vulnPackageCount > 0 ? "nb-alert-danger text-danger" : "nb-alert-success text-success")">
                                                <p class="mb-0 small fw-bold">
                                                    @if (vulnPackageCount > 0)
                                                    {
                                                        <span>⚠️ Attention required: @vulnPackageCount of @totalPackageCount @ecosystemName dependencies have known security risks.</span>
                                                    }
                                                    else
                                                    {
                                                        <span>✅ No package vulnerabilities found in @ecosystemName dependencies (@totalPackageCount checked).</span>
                                                    }
                                                </p>
                                            </div>

                                            @if (vulnPackageCount > 0)
                                            {
                                                <div class="d-flex flex-column gap-3">
                                                    @foreach (var pkg in vulnerablePackages)
                                                    {
                                                        <div class="p-3 border border-2 border-dark bg-white">
                                                            <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
                                                                <h6 class="nb-heading mb-0 text-dark small">
                                                                    📦 @pkg.PackageName
                                                                </h6>
                                                                <span class="nb-badge nb-badge-light font-monospace py-1 px-2 fs-7" style="box-shadow: none;">Version: @pkg.Version</span>
                                                            </div>
                                                            
                                                            <div class="d-flex flex-column gap-2">
                                                                @foreach (var vuln in pkg.Vulnerabilities)
                                                                {
                                                                    var severityClass = vuln.Severity switch
                                                                    {
                                                                        CodeShield.Models.Severity.Critical => "nb-badge typical-theme",
                                                                        CodeShield.Models.Severity.High => "nb-badge typical-theme",
                                                                        CodeShield.Models.Severity.Medium => "nb-badge adventurer-theme",
                                                                        _ => "nb-badge nb-badge-light"
                                                                    };
                                                                    var borderClass = vuln.Severity switch
                                                                    {
                                                                        CodeShield.Models.Severity.Critical => "border-danger",
                                                                        CodeShield.Models.Severity.High => "border-warning",
                                                                        CodeShield.Models.Severity.Medium => "border-info",
                                                                        _ => "border-secondary"
                                                                    };
                                                                    
                                                                    <div class="p-3 bg-white border border-2 border-dark border-start border-5 @borderClass shadow-sm" style="border-left-width: 6px !important;">
                                                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                                                            <span class="fw-bold font-monospace text-secondary small">@vuln.Id</span>
                                                                            <span class="@severityClass py-1 px-2 font-monospace" style="font-size: 0.7rem; box-shadow: none;">@vuln.Severity</span>
                                                                        </div>
                                                                        <p class="mb-2 text-secondary small">@vuln.Description</p>
                                                                        
                                                                        <!-- AI Explanation and Fix Suggestion -->
                                                                        @if (!string.IsNullOrEmpty(vuln.AiExplanation) || !string.IsNullOrEmpty(vuln.AiFixSuggestion))
                                                                        {
                                                                            <div class="mt-3 pt-3 border-top border-dark">
                                                                                @if (!string.IsNullOrEmpty(vuln.AiExplanation))
                                                                                {
                                                                                    <div class="nb-ai-box nb-ai-box-info mb-2">
                                                                                        <span class="d-block nb-heading mb-1 text-start" style="font-size: 0.8rem;">🤖 AI Explanation</span>
                                                                                        <p class="mb-0 text-dark small" style="font-weight: 500;">@vuln.AiExplanation</p>
                                                                                    </div>
                                                                                }
                                                                                @if (!string.IsNullOrEmpty(vuln.AiFixSuggestion))
                                                                                {
                                                                                    <div class="nb-ai-box nb-ai-box-success">
                                                                                        <span class="d-block nb-heading mb-1 text-start" style="font-size: 0.8rem;">💡 Suggested Fix</span>
                                                                                        <p class="mb-0 text-dark small" style="font-weight: 500;">@vuln.AiFixSuggestion</p>
                                                                                    </div>
                                                                                }
                                                                            </div>
                                                                        }
                                                                        else
                                                                        {
                                                                            <div class="mt-3 pt-2 border-top border-dark text-muted small d-flex align-items-center gap-1 nb-mono">
                                                                                <span>🤖</span> <em>AI explanation unavailable for this issue.</em>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="nb-card p-5 text-center text-muted">
                                    <span class="fs-1 d-block mb-3">📁</span>
                                    <h5 class="nb-heading text-dark">No Supported Ecosystems Detected</h5>
                                    <p class="nb-mono small mb-0">This repository does not contain supported package files (e.g., package.json, *.csproj, requirements.txt).</p>
                                </div>
                            }
                        </div>
 
                        <!-- Issues Pane -->
                        <div class="tab-pane fade" id="issues-pane" role="tabpanel" aria-labelledby="issues-tab">
                            @if (Model.CodeIssues == null || Model.CodeIssues.Count == 0)
                            {
                                <div class="nb-card p-5 text-center text-muted">
                                    <span class="fs-1 d-block mb-3">✅</span>
                                    <h5 class="nb-heading text-dark">No Insecure Code Patterns Found</h5>
                                    <p class="nb-mono small mb-0">All scanned source files look secure. No hardcoded secrets, SQL injection risks, exposed configs, or insecure HTTP URLs were found.</p>
                                </div>
                            }
                            else
                            {
                                <div class="nb-card p-4">
                                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom border-dark">
                                        <h5 class="nb-heading mb-0 d-flex align-items-center gap-2">
                                            <span>🔍</span> Code Security Issues
                                        </h5>
                                        <span class="nb-badge py-1 px-3 fs-7">@Model.CodeIssues.Count issues found</span>
                                    </div>
                                    
                                    <div class="d-flex flex-column gap-3">
                                        @foreach (var issue in Model.CodeIssues)
                                        {
                                            var severityClass = issue.Severity switch
                                            {
                                                CodeShield.Models.Severity.Critical => "nb-badge typical-theme",
                                                CodeShield.Models.Severity.High => "nb-badge typical-theme",
                                                CodeShield.Models.Severity.Medium => "nb-badge adventurer-theme",
                                                _ => "nb-badge nb-badge-light"
                                            };
                                            var borderClass = issue.Severity switch
                                            {
                                                CodeShield.Models.Severity.Critical => "border-danger",
                                                CodeShield.Models.Severity.High => "border-warning",
                                                CodeShield.Models.Severity.Medium => "border-info",
                                                _ => "border-secondary"
                                            };

                                            <div class="p-3 border border-2 border-dark bg-white border-start border-5 @borderClass shadow-sm" style="border-left-width: 6px !important;">
                                                <div class="d-flex justify-content-between align-items-start mb-2">
                                                    <div>
                                                        <h6 class="nb-heading mb-1 text-dark small">
                                                            📄 @issue.FileName
                                                        </h6>
                                                        <span class="nb-mono text-muted small" style="font-size: 0.8rem;">Line @issue.LineNumber &bull; <strong class="text-secondary">@issue.IssueType</strong></span>
                                                    </div>
                                                    <span class="@severityClass py-1 px-2 font-monospace" style="font-size: 0.7rem; box-shadow: none;">@issue.Severity</span>
                                                </div>
                                                
                                                <!-- Code Snippet -->
                                                <div class="nb-code-box mb-3 text-start" style="overflow-x: auto; white-space: pre;"><code>@issue.CodeSnippet</code></div>
                                                
                                                <!-- AI Explanation and Fix Suggestion -->
                                                @if (!string.IsNullOrEmpty(issue.AiExplanation) || !string.IsNullOrEmpty(issue.AiFixSuggestion))
                                                {
                                                    <div class="mt-3 pt-3 border-top border-dark">
                                                        @if (!string.IsNullOrEmpty(issue.AiExplanation))
                                                        {
                                                            <div class="nb-ai-box nb-ai-box-info mb-2 text-start">
                                                                <span class="d-block nb-heading mb-1" style="font-size: 0.8rem;">🤖 AI Explanation</span>
                                                                <p class="mb-0 text-dark small" style="font-weight: 500;">@issue.AiExplanation</p>
                                                            </div>
                                                        }
                                                        @if (!string.IsNullOrEmpty(issue.AiFixSuggestion))
                                                        {
                                                            <div class="nb-ai-box nb-ai-box-success text-start">
                                                                <span class="d-block nb-heading mb-1" style="font-size: 0.8rem;">💡 Suggested Fix</span>
                                                                <p class="mb-0 text-dark small" style="font-weight: 500;">@issue.AiFixSuggestion</p>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="mt-3 pt-2 border-top border-dark text-muted small d-flex align-items-center gap-1 nb-mono">
                                                        <span>🤖</span> <em>AI explanation unavailable for this issue.</em>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Files Pane -->
                        <div class="tab-pane fade" id="files-pane" role="tabpanel" aria-labelledby="files-tab">
                            @if (Model.Files != null)
                            {
                                <div class="nb-card p-4">
                                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom border-dark">
                                        <h5 class="nb-heading mb-0">Files Scanned</h5>
                                        <span class="nb-badge nb-badge-light py-1 px-3 fs-7">@Model.Files.Count files</span>
                                    </div>

                                    <div style="max-height: 400px; overflow-y: auto; border: 3px solid var(--color-black);" class="bg-white">
                                        @if (Model.Files.Count == 0)
                                        {
                                            <div class="p-4 text-center text-muted nb-mono small">
                                                No files checked in this repository.
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="list-group list-group-flush">
                                                @foreach (var file in Model.Files)
                                                {
                                                    <div class="list-group-item border-bottom border-dark font-monospace small px-3 py-2 text-dark d-flex align-items-center gap-2">
                                                        <span>📄</span> @file
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('scan-form').addEventListener('submit', function() {
            document.getElementById('scan-loader').classList.remove('d-none');
            document.getElementById('scan-form-card').classList.add('d-none');
            var results = document.getElementById('scan-results-container');
            if (results) {
                results.classList.add('d-none');
            }
        });
    </script>
}

<style>
    @@media print {
        header, footer, nav, .navbar, #scan-form-card, #scan-loader, .nav-pills, .nb-btn, button, form {
            display: none !important;
        }
        body {
            background-color: #ffffff !important;
            color: #000000 !important;
        }
        .container {
            max-width: 100% !important;
            width: 100% !important;
            padding: 0 !important;
            margin: 0 !important;
        }
        .tab-pane {
            display: block !important;
            opacity: 1 !important;
            visibility: visible !important;
        }
        .nb-card, .p-4, .p-3 {
            box-shadow: none !important;
            border: 1px solid #000000 !important;
            break-inside: avoid;
            page-break-inside: avoid;
            margin-bottom: 1.5rem !important;
        }
        .nb-ai-box {
            border: 1px solid #333 !important;
            background-color: #f8f9fa !important;
        }
    }
</style>
