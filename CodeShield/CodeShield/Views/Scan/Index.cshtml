@model CodeShield.Models.ScanViewModel
@{
    ViewData["Title"] = "Scan Repository";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <!-- Scan Form Card -->
            <div class="cs-card p-4 p-md-5 mb-4" id="scan-form-card">
                <div class="text-center mb-4">
                    <span class="fs-1">🔍</span>
                    <h1 class="h3 fw-bold text-dark mt-2">Scan GitHub Repository</h1>
                    <p class="text-muted small">Analyze a public GitHub repository for vulnerable dependencies and security issues.</p>
                </div>

                <form asp-controller="Scan" asp-action="Index" method="post" id="scan-form">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label for="RepositoryUrl" class="form-label fw-semibold text-secondary small">GitHub Repository URL</label>
                        <input type="text" 
                               class="form-control cs-input w-100 @(Model.IsSubmitted && !string.IsNullOrEmpty(Model.ErrorMessage) ? "is-invalid" : "")" 
                               id="RepositoryUrl" 
                               name="RepositoryUrl" 
                               value="@Model.RepositoryUrl" 
                               placeholder="https://github.com/owner/repository" 
                               required />
                        
                        @if (Model.IsSubmitted && !string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <div class="invalid-feedback d-block mt-2 fw-medium text-danger small">
                                ⚠️ @Model.ErrorMessage
                            </div>
                        }
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="cs-btn cs-btn-primary text-white">Analyze Repository</button>
                    </div>
                </form>
            </div>

            <!-- Loading Spinner State -->
            <div class="cs-card p-5 mb-4 text-center d-none" id="scan-loader">
                <div class="cs-loader mb-4"></div>
                <h4 class="fw-bold text-dark">Analyzing Repository...</h4>
                <p class="text-muted small mb-0">Checking file structure, extracting package versions, and querying vulnerability indexes. Please do not close this window.</p>
            </div>

            @if (Model.IsSubmitted && string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div id="scan-results-container">
                    <!-- Warning Banners -->
                    @if (Model.DetectedEcosystems != null && Model.DetectedEcosystems.Contains(CodeShield.Models.Ecosystem.Python) && !Model.DetectedEcosystems.Contains(CodeShield.Models.Ecosystem.Npm) && !Model.DetectedEcosystems.Contains(CodeShield.Models.Ecosystem.NuGet))
                    {
                        <div class="alert cs-alert-warning border-0 shadow-sm p-4 mb-4 rounded-3 d-flex align-items-start" id="python-warning-banner">
                            <span class="fs-3 me-3">⚠️</span>
                            <div>
                                <h5 class="alert-heading fw-bold mb-1">Python Package Scan Limitation</h5>
                                <p class="mb-0 text-dark small">Package vulnerability scanning is disabled for Python repositories. Code pattern scanning is active for Python source files, but no third-party dependency vulnerability checks are performed.</p>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.OsvWarningMessage))
                    {
                        <div class="alert cs-alert-warning border-0 shadow-sm p-4 mb-4 rounded-3 d-flex align-items-start" id="osv-warning-banner">
                            <span class="fs-3 me-3">⚠️</span>
                            <div>
                                <h5 class="alert-heading fw-bold mb-1">Partial Scan Results</h5>
                                <p class="mb-0 text-dark small">@Model.OsvWarningMessage</p>
                            </div>
                        </div>
                    }

                    <!-- Tabs Control -->
                    <ul class="nav cs-nav-pills mb-4" id="scanTabs" role="tablist">
                        <li class="nav-item" role="presentation" style="flex: 1;">
                            <button class="nav-link w-100 active" id="packages-tab" data-bs-toggle="pill" data-bs-target="#packages-pane" type="button" role="tab" aria-controls="packages-pane" aria-selected="true">
                                📦 Package Dependencies
                            </button>
                        </li>
                        <li class="nav-item" role="presentation" style="flex: 1;">
                            <button class="nav-link w-100" id="files-tab" data-bs-toggle="pill" data-bs-target="#files-pane" type="button" role="tab" aria-controls="files-pane" aria-selected="false">
                                📄 Repository File List
                            </button>
                        </li>
                    </ul>

                    <!-- Tabs Content -->
                    <div class="tab-content" id="scanTabsContent">
                        <!-- Packages Pane -->
                        <div class="tab-pane fade show active" id="packages-pane" role="tabpanel" aria-labelledby="packages-tab">
                            @if (Model.DetectedEcosystems != null && Model.DetectedEcosystems.Count > 0)
                            {
                                @foreach (var ecosystem in Model.DetectedEcosystems)
                                {
                                    var ecosystemName = ecosystem == CodeShield.Models.Ecosystem.Npm ? "npm" :
                                                         ecosystem == CodeShield.Models.Ecosystem.NuGet ? "NuGet" : "Python";
                                    var badgeColor = ecosystem == CodeShield.Models.Ecosystem.Npm ? "bg-warning text-dark" :
                                                     ecosystem == CodeShield.Models.Ecosystem.NuGet ? "bg-primary text-white" : "bg-info text-dark";
                                    var ecosystemPackages = Model.Packages?.Where(p => p.Ecosystem == ecosystem).ToList() ?? new List<CodeShield.Models.DependencyPackage>();

                                    <div class="cs-card p-4 mb-4">
                                        <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                                            <h5 class="fw-bold text-dark mb-0 d-flex align-items-center gap-2">
                                                <span>@(ecosystem == CodeShield.Models.Ecosystem.Npm ? "🟢" : ecosystem == CodeShield.Models.Ecosystem.NuGet ? "🔵" : "🐍")</span> 
                                                @ecosystemName Packages
                                            </h5>
                                            <span class="badge @badgeColor px-3 py-2 fw-semibold">@ecosystemPackages.Count packages</span>
                                        </div>

                                        @if (ecosystem == CodeShield.Models.Ecosystem.Python)
                                        {
                                            <div class="alert cs-alert-warning p-3 mb-0 rounded-3">
                                                <p class="mb-0 small fw-medium">
                                                    ⚠️ Package dependency vulnerability scans are currently disabled for Python.
                                                </p>
                                            </div>
                                            @if (ecosystemPackages.Count == 0)
                                            {
                                                <div class="p-4 text-center text-muted small">
                                                    No python dependency packages listed in requirements.txt
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="row g-2 mt-2">
                                                    @foreach (var pkg in ecosystemPackages)
                                                    {
                                                        <div class="col-md-6 col-lg-4">
                                                            <div class="p-2 border rounded-3 bg-light d-flex justify-content-between align-items-center">
                                                                <span class="fw-semibold text-secondary small text-truncate" style="max-width: 120px;">@pkg.PackageName</span>
                                                                <span class="badge bg-white text-dark border font-monospace small">@pkg.Version</span>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            var vulnerablePackages = ecosystemPackages.Where(p => p.Vulnerabilities.Count > 0).ToList();
                                            var vulnPackageCount = vulnerablePackages.Count;
                                            var totalPackageCount = ecosystemPackages.Count;

                                            <div class="p-3 rounded-3 mb-3 @(vulnPackageCount > 0 ? "cs-alert-danger" : "cs-alert-success")">
                                                <p class="mb-0 small fw-semibold">
                                                    @if (vulnPackageCount > 0)
                                                    {
                                                        <span>⚠️ Attention required: @vulnPackageCount of @totalPackageCount @ecosystemName dependencies have known security risks.</span>
                                                    }
                                                    else
                                                    {
                                                        <span>✅ No package vulnerabilities found in @ecosystemName dependencies (@totalPackageCount checked).</span>
                                                    }
                                                </p>
                                            </div>

                                            @if (vulnPackageCount > 0)
                                            {
                                                <div class="d-flex flex-column gap-3">
                                                    @foreach (var pkg in vulnerablePackages)
                                                    {
                                                        <div class="p-3 border rounded-3 bg-light">
                                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                                <h6 class="fw-bold mb-0 text-dark small">
                                                                    📦 @pkg.PackageName
                                                                </h6>
                                                                <span class="badge bg-white text-dark border font-monospace">Version: @pkg.Version</span>
                                                            </div>
                                                            
                                                            <div class="d-flex flex-column gap-2">
                                                                @foreach (var vuln in pkg.Vulnerabilities)
                                                                {
                                                                    var severityClass = vuln.Severity switch
                                                                    {
                                                                        CodeShield.Models.Severity.Critical => "grade-d",
                                                                        CodeShield.Models.Severity.High => "grade-c",
                                                                        CodeShield.Models.Severity.Medium => "bg-info text-dark",
                                                                        _ => "bg-secondary text-white"
                                                                    };
                                                                    var borderClass = vuln.Severity switch
                                                                    {
                                                                        CodeShield.Models.Severity.Critical => "border-danger",
                                                                        CodeShield.Models.Severity.High => "border-warning",
                                                                        CodeShield.Models.Severity.Medium => "border-info",
                                                                        _ => "border-secondary"
                                                                    };
                                                                    
                                                                    <div class="p-3 bg-white rounded-3 border-start border-4 @borderClass shadow-sm">
                                                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                                                            <span class="fw-bold font-monospace text-secondary small">@vuln.Id</span>
                                                                            <span class="badge @severityClass px-2 py-1 font-monospace" style="font-size: 0.7rem; box-shadow: none;">@vuln.Severity</span>
                                                                        </div>
                                                                        <p class="mb-2 text-secondary small">@vuln.Description</p>
                                                                        
                                                                        <!-- AI Explanation and Fix Suggestion -->
                                                                        @if (!string.IsNullOrEmpty(vuln.AiExplanation) || !string.IsNullOrEmpty(vuln.AiFixSuggestion))
                                                                        {
                                                                            <div class="mt-3 pt-3 border-top">
                                                                                @if (!string.IsNullOrEmpty(vuln.AiExplanation))
                                                                                {
                                                                                    <div class="mb-2 bg-light p-2 rounded-2 border-start border-3 border-info">
                                                                                        <span class="d-block fw-bold text-dark mb-1" style="font-size: 0.8rem;">🤖 AI Explanation</span>
                                                                                        <p class="mb-0 text-muted small">@vuln.AiExplanation</p>
                                                                                    </div>
                                                                                }
                                                                                @if (!string.IsNullOrEmpty(vuln.AiFixSuggestion))
                                                                                {
                                                                                    <div class="bg-light p-2 rounded-2 border-start border-3 border-success">
                                                                                        <span class="d-block fw-bold text-dark mb-1" style="font-size: 0.8rem;">💡 Suggested Fix</span>
                                                                                        <p class="mb-0 text-muted small">@vuln.AiFixSuggestion</p>
                                                                                    </div>
                                                                                }
                                                                            </div>
                                                                        }
                                                                        else
                                                                        {
                                                                            <div class="mt-3 pt-2 border-top text-muted small d-flex align-items-center gap-1">
                                                                                <span>🤖</span> <em>AI explanation unavailable for this issue.</em>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="cs-card p-5 text-center text-muted">
                                    <span class="fs-1 d-block mb-3">📁</span>
                                    <h5 class="fw-bold text-dark">No Supported Ecosystems Detected</h5>
                                    <p class="small mb-0">This repository does not contain supported package files (e.g., package.json, *.csproj, requirements.txt).</p>
                                </div>
                            }
                        </div>

                        <!-- Files Pane -->
                        <div class="tab-pane fade" id="files-pane" role="tabpanel" aria-labelledby="files-tab">
                            @if (Model.Files != null)
                            {
                                <div class="cs-card p-4">
                                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                                        <h5 class="fw-bold text-dark mb-0">Files Scanned</h5>
                                        <span class="badge bg-light text-dark border px-3 py-2 fw-semibold">@Model.Files.Count files</span>
                                    </div>

                                    <div style="max-height: 400px; overflow-y: auto;" class="rounded-3 border">
                                        @if (Model.Files.Count == 0)
                                        {
                                            <div class="p-4 text-center text-muted small">
                                                No files checked in this repository.
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="list-group list-group-flush">
                                                @foreach (var file in Model.Files)
                                                {
                                                    <div class="list-group-item font-monospace small px-3 py-2 text-secondary d-flex align-items-center gap-2">
                                                        <span>📄</span> @file
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('scan-form').addEventListener('submit', function() {
            document.getElementById('scan-loader').classList.remove('d-none');
            document.getElementById('scan-form-card').classList.add('d-none');
            var results = document.getElementById('scan-results-container');
            if (results) {
                results.classList.add('d-none');
            }
        });
    </script>
}
