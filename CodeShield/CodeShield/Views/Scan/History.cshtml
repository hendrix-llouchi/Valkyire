@model IEnumerable<CodeShield.Models.ScanResult>
@{
    ViewData["Title"] = "My Scans";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="nb-heading mb-1" style="font-size: 2rem;">MY SCANS</h1>
            <p class="nb-mono text-muted small mb-0 text-uppercase">View your repository scan history and security trends.</p>
        </div>
        <div>
            <a asp-controller="Scan" asp-action="Index" class="nb-btn nb-btn-primary d-flex align-items-center gap-2">
                <span>🔍</span> NEW SCAN
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="nb-card p-5 text-center my-5">
            <span class="fs-1 d-block mb-3">🛡️</span>
            <h4 class="nb-heading mb-3">NO SCAN HISTORY YET</h4>
            <p class="nb-mono text-muted small mx-auto mb-4" style="max-width: 500px; line-height: 1.6;">
                You haven't scanned any GitHub repositories yet. Enter a repository URL to check for security vulnerabilities and code pattern issues.
            </p>
            <div class="d-flex justify-content-center">
                <a asp-controller="Scan" asp-action="Index" class="nb-btn nb-btn-primary">
                    START YOUR FIRST SCAN
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="nb-table-container">
            <div class="table-responsive">
                <table class="table nb-table align-middle">
                    <thead>
                        <tr>
                            <th>Repository</th>
                            <th>Scan Date</th>
                            <th>Security Grade</th>
                            <th>Issues Found</th>
                            <th>Ecosystems</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var scan in Model)
                        {
                            var gradeClass = (scan.SecurityGrade?.StartsWith("A") == true) || (scan.SecurityGrade?.StartsWith("B") == true) ? "nb-grade-a" :
                                             (scan.SecurityGrade?.StartsWith("C") == true) ? "nb-grade-c" : "nb-grade-d";

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="fs-5">📦</span>
                                        <div>
                                            <a asp-controller="Scan" asp-action="Details" asp-route-id="@scan.Id" class="fw-bold text-dark text-decoration-none hover-primary nb-heading" style="font-size: 0.95rem;">
                                                @scan.RepositoryName
                                            </a>
                                            <div class="text-muted small nb-mono" style="font-size: 0.75rem;">
                                                <a href="@scan.RepositoryUrl" target="_blank" class="text-decoration-none text-muted">@scan.RepositoryUrl</a>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="nb-mono text-secondary small">
                                    @scan.ScannedAt.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="nb-grade-badge @gradeClass fw-bold" style="width: 38px; height: 38px; font-size: 0.95rem; box-shadow: 1.5px 1.5px 0px var(--color-black) !important;">@scan.SecurityGrade</span>
                                        @if (scan.Status == CodeShield.Models.ScanStatus.PartialFailure)
                                        {
                                            <span class="nb-badge nb-badge-light py-1 px-2" style="font-size: 0.65rem; box-shadow: none; border-width: 1px !important;">Partial Warning</span>
                                        }
                                    </div>
                                </td>
                                <td class="nb-mono small">
                                    @if (scan.TotalIssuesFound == 0)
                                    {
                                        <span class="text-success fw-bold">✅ NO ISSUES</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold">⚠️ @scan.TotalIssuesFound ISSUES</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(scan.EcosystemsDetected))
                                    {
                                        var ecosystems = scan.EcosystemsDetected.Split(", ");
                                        foreach (var eco in ecosystems)
                                        {
                                            var badgeClass = eco == "Npm" ? "adventurer-theme" :
                                                             eco == "NuGet" ? "rookie-theme" : "nb-badge-light";
                                            <span class="nb-badge @badgeClass py-0 px-2 font-monospace" style="font-size: 0.7rem; box-shadow: none; border-width: 1px !important;">@eco</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted nb-mono" style="font-size: 0.75rem;">None</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end align-items-center gap-2">
                                        <a asp-controller="Scan" asp-action="Details" asp-route-id="@scan.Id" class="nb-btn nb-btn-secondary px-3 py-1 fs-7" style="box-shadow: 2px 2px 0px var(--color-black) !important;">
                                            View
                                        </a>
                                        <a asp-controller="Scan" asp-action="Index" asp-route-repositoryUrl="@scan.RepositoryUrl" class="nb-btn nb-btn-primary px-3 py-1 fs-7" style="box-shadow: 2px 2px 0px var(--color-black) !important;">
                                            Rescan
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .hover-primary:hover {
        color: var(--color-orange-primary) !important;
        text-decoration: underline !important;
    }
</style>
